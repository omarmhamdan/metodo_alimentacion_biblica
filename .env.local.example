# Supabase credentials — copy this file to .env.local and fill in the values.
# Get them from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-public-key

# Admin auth is now handled by Supabase Auth (see supabase-migration-admin-auth.sql).
